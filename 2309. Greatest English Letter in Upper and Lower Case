class Solution:
    def greatestLetter(self, s: str) -> str:
        ss = list(s)
        res = []

        for ch in ss:
            if ch.lower() in ss and ch.upper() in ss:
                res.append(ch.upper())

        test = ''

        if res:
            ress = sorted(set(res))
            test = ress[-1]
        else:
            return test

        return test
