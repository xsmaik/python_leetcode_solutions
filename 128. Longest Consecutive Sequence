class Solution:
    def longestConsecutive(self, nums: List[int]) -> int:
        if nums:
            nums = sorted(set(nums))
            res = 0
            curr = 1

            for i in range(1, len(nums)):
                if nums[i] - nums[i - 1] == 1:
                    curr += 1
                else:
                    res = max(res, curr)
                    curr = 1

            res = max(res, curr)

            return res
        else:
            return 0
