class Solution:
    def relativeSortArray(self, arr1: List[int], arr2: List[int]) -> List[int]:
        res = []
        end = []

        for i in range(len(arr2)):
            for j in range(arr1.count(arr2[i])):
                res.append(arr2[i])

        for i in range(len(arr1)):
            if arr1[i] not in res:
                end.append(arr1[i])

        return res + sorted(end)
