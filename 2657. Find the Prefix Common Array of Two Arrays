class Solution:
    def findThePrefixCommonArray(self, A: List[int], B: List[int]) -> List[int]:
        n = len(A)
        curr_a = []
        curr_b = []

        res = []

        for i in range(n):
            total = 0
            curr_a.append(A[i])
            curr_b.append(B[i])
            for j in range(i + 1):
                if curr_b[j] in curr_a:
                    total += 1
                else:
                    continue

            res.append(total)

        return res
