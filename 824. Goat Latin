class Solution:
    def toGoatLatin(self, sentence: str) -> str:
        sentence = sentence.split()
        chars = ['a', 'e', 'i', 'o', 'u']
        res = []
        char = 'maa'

        for word in sentence:
            if word.lower().startswith(('a', 'e', 'i', 'o', 'u')):
                word += char
                res.append(word)
            else:
                word = word[1:] + word[0] + char
                res.append(word)

            char += 'a'

        return ' '.join(res)
                
